{
  "name": "daemon",
  "version": "4.3.0",
  "main": "dist-electron/main/index.js",
  "description": "Solana-native agent workbench for verifiable AI development",
  "author": "nullxnothing",
  "license": "MIT",
  "private": true,
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:debug": "powershell -NoProfile -Command \"$env:DAEMON_OPEN_DEVTOOLS='1'; vite\"",
    "build": "tsc && vite build",
    "build:daemon-ai-cloud": "vite build --config vite.cloud.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "mobile:seeker": "npm --prefix apps/seeker-mobile run start",
    "mobile:seeker:android": "npm --prefix apps/seeker-mobile run android",
    "mobile:seeker:typecheck": "npm --prefix apps/seeker-mobile run typecheck",
    "package": "pnpm run build && pnpm run rebuild && electron-builder",
    "postinstall": "pnpm run rebuild:native",
    "rebuild": "pnpm run rebuild:native",
    "rebuild:sqlite": "electron-rebuild -f --only better-sqlite3",
    "rebuild:pty": "electron-rebuild -f --only node-pty",
    "rebuild:native": "pnpm run rebuild:sqlite && pnpm run rebuild:pty",
    "preview": "vite preview",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "release:check:local": "pnpm run typecheck && pnpm test && pnpm run test:daemon-ai:cloud-local && pnpm run rebuild && pnpm run test:smoke && pnpm run test:mcp-stress && pnpm run test:pro-entitlement",
    "release:check:v4:local": "pnpm run release:check:local && pnpm run lint:styles && pnpm run test:journeys && pnpm run test:responsive && pnpm run test:layout && pnpm run test:visual && pnpm run test:packaged-smoke",
    "release:check:v4:live": "node scripts/release-tools/v4-live-gate.mjs",
    "release:check:v4:final-state": "node scripts/release-tools/v4-final-state.mjs",
    "release": "npm version patch && git push && git push --tags",
    "pretest": "vite build --mode=test",
    "test": "vitest run",
    "test:unit": "vitest run test/services test/shared test/store test/ui-store.test.ts test/ui-store-extended.test.ts",
    "test:ui": "vitest run test/panels",
    "test:a11y": "vitest run test/a11y",
    "test:keyboard": "vitest run test/keyboard",
    "test:wallet-tx": "vitest run test/services/WalletService.test.ts test/services/WalletService.swap.test.ts test/services/SolanaTransactionPreviewService.test.ts",
    "test:solana-runtime": "vitest run test/services/SolanaRuntimeConfigService.test.ts test/services/SolanaExecutionService.test.ts test/services/SolanaService.test.ts test/services/SolanaRuntimeStatusService.test.ts test/security/BigIntBufferShim.test.ts",
    "test:launch-adapters": "vitest run test/services/TokenLaunchService.test.ts test/services/PumpFunService.test.ts test/services/RaydiumLaunchLabAdapter.test.ts test/services/MeteoraDbcLaunchAdapter.test.ts test/services/OpenBidLaunchAdapter.test.ts",
    "test:x402": "vitest run test/services/IdlePaidCallService.test.ts test/services/ProService.test.ts test/services/DaemonSubscriptionGateway.test.ts",
    "test:metaplex-agentops": "vitest run test/panels/MetaplexOperatorPlan.test.ts",
    "test:deps:solana": "pnpm run security:audit && pnpm why bigint-buffer @solana/web3.js @solana/spl-token @metaplex-foundation/mpl-core @metaplex-foundation/mpl-agent-registry @x402/svm",
    "test:solana": "vitest run test/services/SolanaRuntimeConfigService.test.ts test/services/SolanaExecutionService.test.ts test/services/SolanaService.test.ts test/services/SolanaRuntimeStatusService.test.ts test/services/SolanaTransactionPreviewService.test.ts test/services/WalletService.test.ts test/services/WalletService.swap.test.ts test/services/RecoveryService.test.ts test/services/TokenLaunchService.test.ts test/services/PumpFunService.test.ts test/services/RaydiumLaunchLabAdapter.test.ts test/services/MeteoraDbcLaunchAdapter.test.ts test/services/IdlePaidCallService.test.ts test/services/ValidatorManager.test.ts test/panels/SolanaIntegrations.test.ts test/panels/MetaplexOperatorPlan.test.ts test/panels/IntegrationCommandCenter.registry.test.ts test/panels/IntegrationCommandCenter.sendaiSetup.test.ts test/security/BigIntBufferShim.test.ts",
    "test:security": "vitest run test/security test/services/SecureKeyService.test.ts test/services/ValidationService.test.ts test/services/ProjectSafetyService.test.ts",
    "test:smoke:core": "pnpm run test:smoke && pnpm run test:mcp-stress && pnpm run test:pro-entitlement",
    "test:smoke:ui": "pnpm run test:journeys && pnpm run test:responsive && pnpm run test:layout && pnpm run test:visual",
    "test:ci": "pnpm install --frozen-lockfile --ignore-scripts && pnpm run typecheck && pnpm -r run typecheck && pnpm run lint:styles && pnpm run security:audit && pnpm run test:unit && pnpm run test:ui && pnpm run test:a11y && pnpm run test:keyboard && pnpm run test:solana && pnpm run test:security && pnpm run test:smoke",
    "test:release": "pnpm run release:check:v4:local",
    "test:all": "pnpm run test:ci && pnpm run test:smoke:core && pnpm run test:smoke:ui",
    "test:smoke": "pnpm run build && pnpm run rebuild && node scripts/smoke/electron-smoke.mjs",
    "test:mcp-stress": "pnpm run build && node scripts/smoke/daemon-mcp-stress.mjs",
    "test:pro-entitlement": "pnpm run build && node scripts/smoke/pro-entitlement-flow.mjs",
    "test:scaffold-smoke": "pnpm run build && node scripts/smoke/project-scaffold.mjs",
    "test:replay-devnet": "pnpm run build && node scripts/smoke/replay-devnet-loop.mjs",
    "test:proof-pool-devnet": "pnpm run build && node scripts/smoke/proof-pool-devnet.mjs",
    "test:journeys": "pnpm run build && node scripts/smoke/workflow-journeys.mjs",
    "test:responsive": "pnpm run build && node scripts/smoke/app-responsive.mjs",
    "test:layout": "pnpm run build && node scripts/smoke/layout-cohesion.mjs",
    "test:visual": "pnpm run build && node scripts/smoke/visual-regression.mjs",
    "test:visual:update": "pnpm run build && node scripts/smoke/visual-regression.mjs --update",
    "test:packaged-smoke": "pnpm run package && node scripts/smoke/packaged-app-smoke.mjs",
    "test:daemon-ai:cloud-local": "pnpm run build:daemon-ai-cloud && pnpm rebuild better-sqlite3 && node scripts/smoke/daemon-ai-cloud-local.mjs",
    "test:daemon-ai:live": "node scripts/smoke/daemon-ai-live.mjs",
    "start:daemon-ai-cloud": "node dist-cloud/daemon-ai-cloud-server.mjs",
    "lint:styles": "node scripts/style-debt-check.mjs",
    "security:audit": "pnpm audit --prod --audit-level high && pnpm audit --dev --audit-level high"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/genai": "^1.52.0",
    "@metaplex-foundation/mpl-agent-registry": "^0.2.5",
    "@metaplex-foundation/mpl-core": "^1.10.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@meteora-ag/dynamic-bonding-curve-sdk": "1.5.7",
    "@nirholas/pump-sdk": "1.30.0",
    "@oobe-protocol-labs/synapse-sap-sdk": "0.19.8",
    "@payai/facilitator": "^2.3.6",
    "@phosphor-icons/react": "^2.1.10",
    "@raydium-io/raydium-sdk-v2": "0.2.49-alpha",
    "@solana/kit": "6.9.0",
    "@solana/mpp": "^0.6.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.4",
    "@solflare-wallet/sdk": "^1.4.2",
    "@x402/core": "^2.12.0",
    "@x402/express": "^2.12.0",
    "@x402/extensions": "^2.12.0",
    "@x402/svm": "^2.14.0",
    "better-sqlite3": "^12.10.0",
    "bs58": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "node-pty": "1.1.0",
    "nodemailer": "^8.0.7",
    "pidusage": "^4.0.1",
    "ps-list": "^8.1.1",
    "pyright": "^1.1.409",
    "simple-git": "^3.36.0",
    "smol-toml": "^1.6.1",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@electron/rebuild": "^4.0.4",
    "@monaco-editor/react": "^4.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/bn.js": "^5.2.0",
    "@types/express": "^5.0.1",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "axe-core": "^4.11.4",
    "buffer": "^6.0.3",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "happy-dom": "^20.8.9",
    "monaco-editor": "^0.55.1",
    "patch-package": "^8.0.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^3.2.4",
    "zustand": "^5.0.3"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": "0.8.13",
      "axios": "1.16.1",
      "basic-ftp": "5.3.1",
      "bigint-buffer": "workspace:*",
      "brace-expansion": "5.0.6",
      "dompurify": "3.4.0",
      "esbuild": "0.25.12",
      "hono": "4.12.21",
      "lodash": "4.18.1",
      "follow-redirects": "1.16.0",
      "postcss": "8.5.10",
      "protobufjs": "7.5.8",
      "qs": "6.15.2",
      "tmp": "0.2.6",
      "uuid": "11.1.1",
      "ws": "8.20.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@solana/kit": "6.9.0",
        "@solana/sysvars": "6.9.0"
      }
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-5xrq-8626-4rwp"
      ]
    },
    "patchedDependencies": {
      "node-pty@1.1.0": "patches/node-pty@1.1.0.patch",
      "@oobe-protocol-labs/synapse-sap-sdk@0.19.8": "patches/@oobe-protocol-labs__synapse-sap-sdk@0.19.8.patch"
    }
  }
}
