{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@x402/core/client": [
        "node_modules/@x402/core/dist/esm/client/index.d.mts"
      ],
      "@x402/core/http": [
        "node_modules/@x402/core/dist/esm/http/index.d.mts"
      ],
      "@x402/core/server": [
        "node_modules/@x402/core/dist/esm/server/index.d.mts"
      ],
      "@x402/core/types": [
        "node_modules/@x402/core/dist/esm/types/index.d.mts"
      ],
      "@x402/svm/exact/client": [
        "node_modules/@x402/svm/dist/esm/exact/client/index.d.mts"
      ],
      "@x402/svm/exact/server": [
        "node_modules/@x402/svm/dist/esm/exact/server/index.d.mts"
      ]
    },
  },
  "include": ["src", "electron", "src/types"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
