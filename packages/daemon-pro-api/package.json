{
  "name": "@daemon/pro-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daemon Pro API — subscription server for curated content, arena, and hosted sync",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
